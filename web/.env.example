# =============================================================
# Web Frontend Environment Variables — TEMPLATE
# Copy this file to .env and fill in real values.
# All REACT_APP_* variables are embedded in the browser bundle —
# do NOT put secrets here.
# =============================================================

# Backend API base URL (with /api suffix — used for all API calls)
REACT_APP_API_BASE_URL=http://localhost:3000/api

# Backend root URL (no /api suffix — used for OAuth redirect links)
REACT_APP_API_URL=http://localhost:3000

# Razorpay public key (safe to expose — it's a public key, not secret)
REACT_APP_RAZORPAY_KEY_ID=your_razorpay_key_id_here
