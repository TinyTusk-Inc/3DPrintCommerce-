# Docker Compose Environment Variables
# This file is sourced by docker-compose.yml for database credentials
# Create a .env file in project root and configure these values

# Database Configuration
DB_HOST=postgres
DB_PORT=5432
DB_NAME=ecommerce_3d_db
DB_USER=postgres
DB_PASSWORD=postgres

# Node.js Environment (if running backend in Docker)
NODE_ENV=development
PORT=3000
