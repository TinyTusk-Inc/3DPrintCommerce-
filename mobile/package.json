{
  "name": "3d-ecommerce-mobile",
  "version": "0.1.0",
  "description": "React Native mobile app for 3D Product Ecommerce Platform",
  "private": true,
  "main": "index.js",
  "scripts": {
    "android": "react-native run-android",
    "ios": "react-native run-ios",
    "start": "react-native start",
    "build:android": "cd android && ./gradlew assembleRelease",
    "build:ios": "xcodebuild -workspace ios/ThreeDPrintEcommerce.xcworkspace -scheme ThreeDPrintEcommerce -configuration Release",
    "test": "jest"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-native": "^0.71.0",
    "axios": "^1.3.0"
  },
  "devDependencies": {
    "@react-native-community/eslint-config": "^3.1.0",
    "babel-jest": "^29.5.0",
    "jest": "^29.5.0",
    "metro-react-native-babel-preset": "^0.73.9"
  }
}
