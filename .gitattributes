# Auto detect text files and normalize line endings to LF
* text=auto eol=lf

# Source code files - always LF
*.js text eol=lf
*.jsx text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.py text eol=lf

# Configuration files - always LF
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.env text eol=lf
*.env.* text eol=lf

# Documentation - always LF
*.md text eol=lf
*.txt text eol=lf
*.markdown text eol=lf

# Shell scripts - always LF
*.sh text eol=lf
*.bash text eol=lf

# SQL files - always LF
*.sql text eol=lf

# Docker files - always LF
Dockerfile text eol=lf
docker-compose.yml text eol=lf
docker-compose.*.yml text eol=lf
.dockerignore text eol=lf

# Git files - always LF
.gitignore text eol=lf
.gitattributes text eol=lf

# Binary files - no conversion
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.svg binary
*.zip binary
*.tar binary
*.tar.gz binary
*.rar binary
*.7z binary
*.exe binary
*.dll binary
*.so binary
*.dylib binary

# Node modules and dependencies
node_modules/** -text linguist-vendored
package-lock.json merge=union
yarn.lock merge=union

# IDE specific files
.vscode/** text eol=lf
.idea/** text eol=lf
*.swp text eol=lf
*.swo text eol=lf
