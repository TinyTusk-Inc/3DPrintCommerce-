# =============================================================
# Backend Environment Variables — TEMPLATE
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# =============================================================

# Server
PORT=3000
ADMIN_PORT=3002

# Frontend URL (used for OAuth post-login redirect and CORS)
FRONTEND_URL=http://localhost:3001
ADMIN_FRONTEND_URL=http://localhost:3002

# =============================================================
# Database (PostgreSQL)
# =============================================================
DB_HOST=localhost        # Use 'postgres' when running inside Docker
DB_PORT=5432
DB_NAME=ecommerce_3d_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# =============================================================
# JWT Authentication
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================================
JWT_SECRET=your_jwt_secret_key_here_min_32_chars
JWT_EXPIRE=7d

# =============================================================
# Admin account (used by scripts/create-admin.js — run once)
# =============================================================
ADMIN_EMAIL=admin@yourstore.com
ADMIN_PASSWORD=your_strong_admin_password_here

# =============================================================
# Razorpay (Payment Gateway)
# =============================================================
RAZORPAY_KEY_ID=your_key_id_here
RAZORPAY_KEY_SECRET=your_key_secret_here
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# =============================================================
# Email Service (Nodemailer — Gmail for dev, SendGrid for prod)
# Gmail: enable 2FA → generate App Password at myaccount.google.com/apppasswords
# =============================================================
EMAIL_SERVICE=gmail
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_app_password_here
EMAIL_FROM_NAME=3D Print Store
SENDGRID_API_KEY=your_sendgrid_key_here

# =============================================================
# OAuth — Social Login (Google)
# Create at: console.cloud.google.com → APIs & Services → Credentials
# =============================================================
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_CALLBACK_URL=http://localhost:3000/api/auth/google/callback

# =============================================================
# OAuth — Social Login (Facebook)
# Create at: developers.facebook.com → My Apps
# =============================================================
FACEBOOK_APP_ID=your_facebook_app_id_here
FACEBOOK_APP_SECRET=your_facebook_app_secret_here
FACEBOOK_CALLBACK_URL=http://localhost:3000/api/auth/facebook/callback

# =============================================================
# File Storage — choose one: AWS S3 or Cloudinary
# =============================================================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_REGION=ap-south-1
AWS_S3_BUCKET=your_bucket_name

CLOUDINARY_NAME=your_name
CLOUDINARY_API_KEY=your_api_key
CLOUDINARY_API_SECRET=your_api_secret

# =============================================================
# Virus Scanning (Phase 5 — custom orders)
# =============================================================
CLAMAV_HOST=localhost
CLAMAV_PORT=3310
VIRUSTOTAL_API_KEY=your_api_key_here

# =============================================================
# Secrets Management (production — see VAULT_SETUP.md)
# Leave blank for local dev; vault.js falls back to .env values
# =============================================================
VAULT_ADDR=
VAULT_ROLE_ID=
VAULT_SECRET_ID=
